# ===== PUSH-DOE-SC — modelo de configuração =====
# Copie para .env e ajuste. O .env nunca deve ser versionado.

# --- Fonte de clientes ---
# Aceita .txt (NOME ou NOME;CNH por linha) ou .xlsx.
CLIENTS_FILE=./clientes.txt
# Colunas da planilha .xlsx (opcional). Vazio = auto-detecta pelo cabeçalho.
# Aceita letra ("B") ou índice 0-based ("1").
NAME_COLUMN=
CNH_COLUMN=

# --- Arquivos gerados ---
CSV_DIR=./csv
HISTORY_PATH=./data/vistos.json
# Histórico/deduplicação: true (uso recorrente) ou false (cada busca independente).
USE_HISTORY=true

# --- E-mail (opcional) ---
# Se deixar em branco, o relatório sai apenas como arquivos CSV (sem e-mail).
# Office 365: smtp.office365.com / 587 / secure=false  | Gmail: smtp.gmail.com / 587 / secure=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
